# GitHub OAuth token for Copilot CLI authentication.
# Get your token with:  gh auth token
# This is passed as COPILOT_GITHUB_TOKEN inside the container.
COPILOT_TOKEN=

# Your GitHub username (must match the token owner).
COPILOT_USER=cjennison

# Optional: run Copilot CLI non-interactively with a specific prompt.
# When set, the container runs the prompt and exits.
# COPILOT_PROMPT=Search Google for New Hampshire building codes and report the front page results

# ADU feasibility mode: set an address and the container autonomously produces
# a feasibility report (reports/<slug>.md) then exits.
# ADDRESS=1341 River Road, Manchester, NH
